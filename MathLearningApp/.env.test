# 集成测试环境变量
# Story 8-4: CI/CD 集成

# 测试环境标识
NODE_ENV=test

# 数据库配置
DATABASE_URL=mysql://test:test@localhost:3306/math_test
DATABASE_POOL_SIZE=5
DATABASE_CONNECTION_TIMEOUT=5000

# API配置
API_BASE_URL=http://localhost:3000
API_TIMEOUT=30000

# 认证配置
JWT_SECRET=test-jwt-secret-key-do-not-use-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# 第三方服务配置 (使用mock或测试实例)
BAIDU_OCR_API_KEY=test-api-key
BAIDU_OCR_SECRET_KEY=test-secret-key
DEEPSEEK_API_KEY=test-deepseek-key

# 缓存配置
REDIS_URL=redis://localhost:6379/1
CACHE_TTL=3600

# 日志配置
LOG_LEVEL=error
LOG_FORMAT=json

# 测试配置
TEST_TIMEOUT=30000
TEST_RETRY_ATTEMPTS=2
TEST_PARALLEL_WORKERS=4

# 功能开关
ENABLE_OFFLINE_MODE=true
ENABLE_CACHE=true
ENABLE_MOCK_SERVICES=true
