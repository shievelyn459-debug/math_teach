# ============================================================
# MathLearningApp 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际的 API 密钥

# ============================================================
# 百度 OCR 配置
# ============================================================
# 获取方式: https://console.bce.baidu.com/ai/#/ai/ocr/overview/index
BAIDU_OCR_API_KEY=your_baidu_api_key_here
BAIDU_OCR_SECRET_KEY=your_baidu_secret_key_here
# 可选: 如果已有访问令牌，可以直接填入（会自动刷新）
BAIDU_OCR_ACCESS_TOKEN=

# ============================================================
# DeepSeek 配置
# ============================================================
# 获取方式: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# ============================================================
# OpenAI 配置（可选，用于降级）
# ============================================================
# 获取方式: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================================
# 服务提供商选择
# ============================================================
# OCR 提供商: baidu (推荐) 或 openai
OCR_PROVIDER=baidu
# 题目生成提供商: deepseek (推荐) 或 openai
GENERATION_PROVIDER=deepseek

# ============================================================
# 功能开关
# ============================================================
# 启用 AI 生成（关闭则只使用本地题库）
ENABLE_AI_GENERATION=true
# 启用本地降级（AI 失败时使用本地题库）
USE_LOCAL_FALLBACK=true

# ============================================================
# 开发配置
# ============================================================
# API 调试日志
DEBUG_API=false
# 缓存开关
ENABLE_CACHE=true

# ============================================================
# MySQL 数据库配置
# ============================================================
# 格式: mysql://用户名:密码@主机:端口/数据库名?参数
#
# 本地开发环境示例:
# DATABASE_URL="mysql://root:YOUR_SECURE_PASSWORD@localhost:3306/mathlearning?connection_limit=10"
#
# 生产环境示例（推荐配置）:
# DATABASE_URL="mysql://mathapp:STRONG_PASSWORD_HERE@your-server-ip:3306/mathlearning?connection_limit=20&pool_timeout=20&connect_timeout=10"
#
# 参数说明:
# - connection_limit: 连接池大小（默认10，生产环境建议20-50）
# - pool_timeout: 连接池超时秒数（默认20）
# - connect_timeout: 连接超时秒数（默认10）
#
# 自建服务器配置步骤:
# 1. 租用云服务器（推荐配置：2核4G，20GB SSD）
# 2. 安装MySQL 8.0+（参考 Story 6-1 中的安装指南）
# 3. 创建数据库: CREATE DATABASE mathlearning CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# 4. 创建用户: CREATE USER 'mathapp'@'%' IDENTIFIED BY 'strong_unique_password';
# 5. 授权: GRANT ALL ON mathlearning.* TO 'mathapp'@'%';
# 6. 更新此文件中的连接信息，并替换YOUR_SECURE_PASSWORD
DATABASE_URL="mysql://root:YOUR_SECURE_PASSWORD@localhost:3306/mathlearning?connection_limit=10"
